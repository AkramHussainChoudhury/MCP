# ── Required: MCP server auth ────────────────────────────────────────────────
# Shared secret between server.py and agent.py.
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
# Leave blank to disable auth (local dev only).
MCP_API_KEY=your_mcp_api_key_here

# ── Required: LLM ───────────────────────────────────────────────────────────
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ── Optional: LangSmith tracing ──────────────────────────────────────────────
# Get yours at: https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=databricks-observability

# ── Optional: Real Databricks connection ─────────────────────────────────────
# Leave blank to use mock data (local dev / demo mode).
# Set both to connect to a real Databricks workspace.
#
# DATABRICKS_HOST  — workspace URL, e.g. https://adb-123456789.0.azuredatabricks.net
# DATABRICKS_TOKEN — personal access token (Settings → Developer → Access tokens)
DATABRICKS_HOST=
DATABRICKS_TOKEN=

# Required only when DATABRICKS_HOST is set:
# DATABRICKS_WAREHOUSE_ID — SQL warehouse ID used for DESCRIBE DETAIL / HISTORY queries
#                           (SQL Warehouses → your warehouse → Connection details)
DATABRICKS_WAREHOUSE_ID=

# Optional — used when listing all tables without specifying a table name
DATABRICKS_CATALOG=main
DATABRICKS_SCHEMA=default
